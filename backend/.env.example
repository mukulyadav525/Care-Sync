# Copy to .env (or export in your shell) and fill in real values for any
# non-development deployment. settings.py reads all of these from the env.

# Core
DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=example.com,www.example.com

# Email (used to deliver OTP / 2FA codes). When DEBUG=True and these are unset,
# emails are printed to the console instead.
EMAIL_HOST_USER=m2.healthtech@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# Google OAuth / Sheets (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

