# xAI (Grok) API key used by the AI agent pipeline (chatbot + report agents).
# Get one at https://console.x.ai
XAI_API_KEY=

# Comma-separated list of extra origins allowed to call this API in
# production (your Netlify site URL, custom domain, etc). localhost:3000 is
# always allowed for local dev, no need to list it here.
#   CORS_ALLOWED_ORIGINS=https://caresync.netlify.app,https://caresync.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Directory of a trained HRV forecasting checkpoint (meta.joblib,
# scaler.joblib, <model>_model.pt or xgb/) — leave blank to serve the mock
# forecast engine. Anomaly detection and the digital twin work for real
# without this. See docs/HRV_INTEGRATION.md.
HRV_MODEL_DIR=
